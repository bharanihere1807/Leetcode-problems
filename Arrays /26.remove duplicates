int removeDuplicates(int* nums, int numsSize) {
   
   int res =1;
   for(int i=1;i<numsSize;i++){  // initilize with 1
      if(nums[i] !=nums[i-1]){    //check current and previous element whether not same
          nums[res] = nums[i];   //store in other
          res++;               // increment this
      }
   }
   return res;
}
